___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const createArgumentsQueue = require('createArgumentsQueue');
const injectScript = require('injectScript');
const copyFromWindow = require('copyFromWindow');
const setInWindow = require('setInWindow');
const callInWindow = require('callInWindow');
const makeNumber = require('makeNumber');

// illumin (formerly AcuityAds) Universal Pixel loader
// Source: https://origin.acuityplatform.com/event/v2/pixel.js
const scriptUrl = 'https://origin.acuityplatform.com/event/v2/pixel.js';

// Build event object from GTM UI fields.
// Field names match the illumin pixel API parameters directly.
//
// pixelKey (required) — Unique pixel identifier assigned by illumin when
//                        creating a Universal Pixel (e.g. "9180448253778427401").
// pg       (optional) — Page Group ID, numeric identifier for the page event
//                        mapping created in illumin (e.g. 49135).
// prodid   (optional) — Advertiser Product ID, used for dynamic cart tracking.
//                        Supports arrays — the pixel joins multiple IDs with "~".
// ordid    (optional) — Advertiser Order ID, used for conversion/order tracking.
// crev     (optional) — Cart Revenue value associated with the conversion.
// delay    (optional) — Delay in milliseconds before the pixel fires.
const eventData = {pixelKey: data.pixelKey};

if (data.pg) {
  eventData.pg = makeNumber(data.pg);
}
if (data.prodid) {
  eventData.prodid = data.prodid;
}
if (data.ordid) {
  eventData.ordid = data.ordid;
}
if (data.crev) {
  eventData.crev = data.crev;
}
if (data.delay) {
  eventData.delay = makeNumber(data.delay);
}

// Check if the illumin pixel script is already initialized on the page.
// The original integration snippet (see source/illumin-original-integration-script.md)
// guards with `if (!window.aap)` to avoid double-loading. We replicate that
// by checking for the global `aap` function before re-injecting.
const existingAap = copyFromWindow('aap');

if (existingAap) {
  // Pixel already loaded (by another tag instance or hard-coded on the page) —
  // just fire the event without re-injecting the script.
  callInWindow('aap', eventData);
  data.gtmOnSuccess();
} else {
  // First load: set up the command queue (window.aap → window.acuityAdsEventQueue)
  // and inject the pixel script exactly once (cacheToken prevents duplicates).
  const aap = createArgumentsQueue('aap', 'acuityAdsEventQueue');

  // Piggyback callback required by the illumin pixel for server responses
  setInWindow('acuityPiggybackCallback', function(e) {
    callInWindow('acuityParseResponse', e);
  }, false);

  aap(eventData);

  injectScript(scriptUrl, data.gtmOnSuccess, data.gtmOnFailure, 'illuminPixel');
}


