- name: Piggyback callback is registered on first load
  code: |-
    // =============================================================================
    // Test: Piggyback callback is registered on first load
    // =============================================================================
    let setInWindowCalls = [];
    mock("copyFromWindow", function (key) {
      return undefined;
    });
    mock("createArgumentsQueue", function (fnName, arrayName) {
      return function () {};
    });
    mock("setInWindow", function (key, value, overwrite) {
      setInWindowCalls.push({ key: key, overwrite: overwrite });
    });
    mock("callInWindow", function () {});
    mock("injectScript", function (url, onSuccess, onFailure, cacheToken) {
      onSuccess();
    });

    const mockDataCallback = {
      pixelKey: "9180448253778427401",
      gtmOnSuccess: function () {},
      gtmOnFailure: function () {},
    };

    runCode(mockDataCallback);

    // Verify acuityPiggybackCallback was set with overwrite=false
    assertThat(setInWindowCalls.length).isEqualTo(1);
    assertThat(setInWindowCalls[0].key).isEqualTo("acuityPiggybackCallback");
    assertThat(setInWindowCalls[0].overwrite).isEqualTo(false);
