scenarios:
- name: First load — pixelKey only (minimum required fields)
  code: |-
    // =============================================================================
    // Test: First load — pixelKey only (minimum required fields)
    // =============================================================================
    mock("copyFromWindow", function (key) {
      return undefined;
    });
    mock("createArgumentsQueue", function (fnName, arrayName) {
      return function () {};
    });
    mock("setInWindow", function () {});
    mock("callInWindow", function () {});

    let injectScriptArgs;
    mock("injectScript", function (url, onSuccess, onFailure, cacheToken) {
      injectScriptArgs = {
        url: url,
        cacheToken: cacheToken
      };
      onSuccess();
    });

    const mockDataMinimal = {
      pixelKey: "9180448253778427401",
      gtmOnSuccess: function () {},
      gtmOnFailure: function () {},
    };

    runCode(mockDataMinimal);

    assertApi("gtmOnSuccess").wasCalled();
    assertApi("gtmOnFailure").wasNotCalled();
    assertApi("createArgumentsQueue").wasCalledWith("aap", "acuityAdsEventQueue");
    assertApi("setInWindow").wasCalled();

    // Verify injectScript arguments manually to avoid function reference equality issues
    assertThat(injectScriptArgs).isDefined();
    assertThat(injectScriptArgs.url).isEqualTo("https://origin.acuityplatform.com/event/v2/pixel.js");
    assertThat(injectScriptArgs.cacheToken).isEqualTo("illuminPixel");
